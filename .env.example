DATABASE_URL=mysql+pymysql://root:password@db:3306/myapp?charset=utf8mb4

LOCAL_LLM_BASE_URL=http://host.docker.internal:9000
LOCAL_LLM_TIMEOUT_SEC=120
LOCAL_LLM_MODEL_NAME=gemma

RAG_EMBEDDING_PROVIDER=sentence_transformer
RAG_EMBEDDING_MODEL_NAME=BAAI/bge-m3
RAG_EMBEDDING_DEVICE=
RAG_EMBEDDING_NORMALIZE=true
RAG_EMBEDDING_DIMENSIONS=32
RAG_EMBEDDING_QUERY_INSTRUCTION=
RAG_EMBEDDING_DOCUMENT_INSTRUCTION=

RAG_QDRANT_HOST=qdrant
RAG_QDRANT_HTTP_PORT=6333
RAG_QDRANT_GRPC_PORT=6334
RAG_QDRANT_COLLECTION_NAME=rag_chunks
RAG_QDRANT_PREFER_GRPC=false
RAG_QDRANT_HTTPS=false
RAG_QDRANT_API_KEY=
RAG_QDRANT_TIMEOUT_SEC=10
